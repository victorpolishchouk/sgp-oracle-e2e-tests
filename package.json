{
  "name": "sgp-oracle-e2e-tests",
  "version": "1.0.0",
  "description": "Playwright E2E automated tests for SGP Oracle prediction application",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:codegen": "playwright codegen https://victorpolishchouk.github.io/sgp-oracle/",
    
    "test:smoke": "playwright test --grep @smoke",
    "test:security": "playwright test --grep @security",
    "test:regression": "playwright test --grep @regression",
    "test:accessibility": "playwright test --grep @accessibility",
    "test:critical": "playwright test --grep @critical",
    
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile",
    
    "test:parallel": "playwright test --workers=4",
    "test:sequential": "playwright test --workers=1",
    
    "report": "playwright show-report",
    "report:open": "npx playwright show-report playwright-report",
    
    "install:browsers": "playwright install --with-deps",
    "install:chromium": "playwright install --with-deps chromium",
    
    "lint": "eslint tests/**/*.ts",
    "format": "prettier --write 'tests/**/*.{ts,js,json}'",
    
    "ci:smoke": "playwright test --project=chromium --grep @smoke --reporter=html,json",
    "ci:full": "playwright test --reporter=html,json,junit"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "automation",
    "qa",
    "sgp-oracle"
  ],
  "author": "QA Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@axe-core/playwright": "^4.8.5",
    "@types/node": "^20.11.19",
    "dotenv": "^16.4.5",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
