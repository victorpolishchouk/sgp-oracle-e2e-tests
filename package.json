{
  "name": "sgp-oracle-e2e-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E tests for SGP Oracle (https://victorpolishchouk.github.io/sgp-oracle/)",
  "scripts": {
    "test": "playwright test",
    "test:sgp-auth": "playwright test tests/sgp-oracle-auth.spec.ts --project=chromium",
    "test:sgp-happy": "playwright test tests/sgp-oracle-happy-path.spec.ts --project=chromium",
    "test:report": "playwright show-report playwright-report"
